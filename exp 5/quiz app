<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>JS Quiz with Timer</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body{
            font-family: Arial, sans-serif;
            background:#f4f4f8;
            margin:0;
            padding:20px;
        }
        .quiz-box{
            max-width:700px;
            margin:20px auto;
            background:#fff;
            padding:20px 24px;
            border-radius:10px;
            box-shadow:0 4px 14px rgba(0,0,0,0.15);
            border:1px solid #ddd;
        }
        h1{
            margin-top:0;
            text-align:center;
            color:#0056d6;
        }
        .timer-row{
            display:flex;
            justify-content:space-between;
            align-items:center;
            margin-bottom:10px;
        }
        #timer{
            font-weight:bold;
            font-size:1.1rem;
        }
        #warning{
            color:#d00000;
            font-weight:bold;
        }
        .question{
            margin-bottom:12px;
        }
        .options{
            margin-left:10px;
            margin-bottom:16px;
        }
        button{
            padding:8px 16px;
            border-radius:18px;
            border:none;
            background:#0056d6;
            color:#fff;
            cursor:pointer;
            font-weight:bold;
        }
        button:disabled{
            background:#999;
            cursor:not-allowed;
        }
        #scoreBox{
            margin-top:15px;
            padding:10px;
            text-align:center;
            border-radius:8px;
            background:#e9ecef;
            font-weight:bold;
        }
    </style>
</head>
<body>

<div class="quiz-box">
    <h1>JavaScript Basics Quiz</h1>

    <div class="timer-row">
        <div id="timer">Time: 10s</div>
        <div id="warning"></div>
    </div>

    <form id="quizForm">
        <!-- Q1 -->
        <div class="question">
            1. Which method is used to repeatedly call a function in JavaScript?
        </div>
        <div class="options">
            <label><input type="radio" name="q1" value="a"> setTimeout()</label><br>
            <label><input type="radio" name="q1" value="b"> setInterval()</label><br>
            <label><input type="radio" name="q1" value="c"> clearInterval()</label><br>
            <label><input type="radio" name="q1" value="d"> loop()</label>
        </div>

        <!-- Q2 -->
        <div class="question">
            2. Which keyword declares a block-scoped variable?
        </div>
        <div class="options">
            <label><input type="radio" name="q2" value="a"> var</label><br>
            <label><input type="radio" name="q2" value="b"> let</label><br>
            <label><input type="radio" name="q2" value="c"> const</label><br>
            <label><input type="radio" name="q2" value="d"> function</label>
        </div>

        <!-- Q3 -->
        <div class="question">
            3. Which symbol is used for strict equality?
        </div>
        <div class="options">
            <label><input type="radio" name="q3" value="a"> ==</label><br>
            <label><input type="radio" name="q3" value="b"> =</label><br>
            <label><input type="radio" name="q3" value="c"> ===</label><br>
            <label><input type="radio" name="q3" value="d"> !=</label>
        </div>

        <!-- Q4 -->
        <div class="question">
            4. DOM stands for:
        </div>
        <div class="options">
            <label><input type="radio" name="q4" value="a"> Document Object Model</label><br>
            <label><input type="radio" name="q4" value="b"> Data Object Model</label><br>
            <label><input type="radio" name="q4" value="c"> Document Oriented Markup</label><br>
            <label><input type="radio" name="q4" value="d"> Dynamic Object Mode</label>
        </div>

        <!-- Q5 -->
        <div class="question">
            5. Which HTML tag is used to include JavaScript?
        </div>
        <div class="options">
            <label><input type="radio" name="q5" value="a"> &lt;style&gt;</label><br>
            <label><input type="radio" name="q5" value="b"> &lt;link&gt;</label><br>
            <label><input type="radio" name="q5" value="c"> &lt;js&gt;</label><br>
            <label><input type="radio" name="q5" value="d"> &lt;script&gt;</label>
        </div>

        <button type="button" id="startBtn">Start Quiz</button>
        <button type="button" id="submitBtn" onclick="submitQuiz()" disabled>Submit</button>
    </form>

    <div id="scoreBox">Score will appear here.</div>
</div>

<script>
    const correctAnswers = {
        q1: "b",
        q2: "b",
        q3: "c",
        q4: "a",
        q5: "d"
    };

    let remaining = 10;
    let timerId = null;
    const timerEl = document.getElementById('timer');
    const warningEl = document.getElementById('warning');
    const startBtn = document.getElementById('startBtn');
    const submitBtn = document.getElementById('submitBtn');

    startBtn.onclick = function () {
        startBtn.disabled = true;
        submitBtn.disabled = false;
        startTimer();
    };

    function startTimer() {
        timerEl.textContent = `Time: ${remaining}s`;
        timerId = setInterval(() => {
            remaining--;
            timerEl.textContent = `Time: ${remaining}s`;

            if (remaining === 5) {
                warningEl.textContent = "Only 5 seconds remaining!";
            }
            if (remaining <= 0) {
                clearInterval(timerId); // stop timer
                warningEl.textContent = "Time is up!";
                submitQuiz();           // auto-submit
            }
        }, 1000);
    }

    function submitQuiz() {
        // prevent double submit
        if (submitBtn.disabled) return;

        clearInterval(timerId);
        submitBtn.disabled = true;

        // disable all options
        const allOptions = document.querySelectorAll('input[type="radio"]');
        allOptions.forEach(opt => opt.disabled = true);

        // calculate score
        let score = 0;
        for (let key in correctAnswers) {
            const selected = document.querySelector(`input[name="${key}"]:checked`);
            if (selected && selected.value === correctAnswers[key]) {
                score++;
            }
        }

        document.getElementById('scoreBox').textContent =
            `Final Score: ${score} / 5`;
    }
</script>
</body>
</html>

