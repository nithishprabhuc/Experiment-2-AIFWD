<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Event Countdown Timer</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <style>
        body{
            font-family: Arial, sans-serif;
            background:#0b1320;
            color:#f8f9fa;
            margin:0;
            padding:20px;
        }
        .wrapper{
            max-width:600px;
            margin:40px auto;
            background:#101826;
            padding:20px 24px;
            border-radius:10px;
            box-shadow:0 4px 15px rgba(0,0,0,0.4);
        }
        h1{
            margin-top:0;
            text-align:center;
            color:#ffd166;
        }
        .countdown{
            display:flex;
            justify-content:space-around;
            margin:20px 0;
        }
        .time-box{
            text-align:center;
        }
        .time-box span{
            display:block;
            font-size:1.5rem;
            font-weight:bold;
        }
        .label{
            font-size:0.85rem;
            color:#ced4da;
        }
        #statusMsg{
            text-align:center;
            font-weight:bold;
            margin-top:10px;
        }
        .form-box{
            margin-top:25px;
            background:#151d2c;
            padding:15px;
            border-radius:8px;
        }
        label{
            display:block;
            margin-bottom:4px;
        }
        input[type="text"],
        input[type="email"]{
            width:100%;
            padding:8px;
            border-radius:4px;
            border:1px solid #555;
            background:#0b1320;
            color:#fff;
        }
        button{
            margin-top:10px;
            padding:8px 18px;
            border-radius:20px;
            border:none;
            cursor:pointer;
            background:#06d6a0;
            color:#101826;
            font-weight:bold;
        }
        button:disabled{
            background:#555;
            cursor:not-allowed;
        }
    </style>
</head>
<body>

<div class="wrapper">
    <h1>Registration Countdown</h1>

    <div class="countdown">
        <div class="time-box">
            <span id="days">0</span>
            <span class="label">Days</span>
        </div>
        <div class="time-box">
            <span id="hours">0</span>
            <span class="label">Hours</span>
        </div>
        <div class="time-box">
            <span id="minutes">0</span>
            <span class="label">Minutes</span>
        </div>
        <div class="time-box">
            <span id="seconds">0</span>
            <span class="label">Seconds</span>
        </div>
    </div>

    <div id="statusMsg">Registration Open</div>

    <div class="form-box">
        <h3>Event Registration</h3>
        <form id="regForm">
            <label for="name">Name</label>
            <input type="text" id="name" required>

            <label for="email">Email</label>
            <input type="email" id="email" required>

            <button type="submit" id="regBtn">Register</button>
        </form>
    </div>
</div>

<script>
    // Set future event date (e.g., 2 minutes from now for demo)
    const now = new Date();
    const eventDate = new Date(now.getTime() + 2 * 60 * 1000); // 2 mins later

    const daysEl = document.getElementById('days');
    const hoursEl = document.getElementById('hours');
    const minutesEl = document.getElementById('minutes');
    const secondsEl = document.getElementById('seconds');
    const statusMsg = document.getElementById('statusMsg');
    const regBtn = document.getElementById('regBtn');

    const second = 1000,
          minute = second * 60,
          hour   = minute * 60,
          day    = hour * 24;

    function updateCountdown() {
        const nowTime = new Date().getTime();
        const targetTime = eventDate.getTime();
        const diff = targetTime - nowTime;

        if (diff <= 0) {
            clearInterval(countdownId);
            daysEl.textContent = 0;
            hoursEl.textContent = 0;
            minutesEl.textContent = 0;
            secondsEl.textContent = 0;

            statusMsg.textContent = "Registration Closed";
            regBtn.disabled = true;
            return;
        }

        const d = Math.floor(diff / day);
        const h = Math.floor((diff % day) / hour);
        const m = Math.floor((diff % hour) / minute);
        const s = Math.floor((diff % minute) / second);

        daysEl.textContent = d;
        hoursEl.textContent = h;
        minutesEl.textContent = m;
        secondsEl.textContent = s;
    }

    // setInterval with Date math
    const countdownId = setInterval(updateCountdown, 1000);
    updateCountdown(); // initial call
</script>
</body>
</html>